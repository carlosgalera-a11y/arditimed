rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══ Helpers ══════════════════════════════════════════════════════
    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }
    // Admin via custom claim primary; hardcoded fallback para migración.
    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true
        || request.auth.token.role == 'superadmin'
        || request.auth.token.role == 'admin'
        || request.auth.token.email == 'carlosgalera2roman@gmail.com'
        || request.auth.token.email == 'ramongalera22@gmail.com'
      );
    }
    // Moderador: doc en /moderadores/{email} con activo:true.
    // El admin gestiona la lista desde el Panel de Moderación. Permite que
    // moderadores sin custom claim puedan aprobar propuestas, marcar
    // documentos como visibles, etc., sin tener admin global.
    function isModerator() {
      return signedIn() && request.auth.token.email != null
        && exists(/databases/$(database)/documents/moderadores/$(request.auth.token.email))
        && get(/databases/$(database)/documents/moderadores/$(request.auth.token.email)).data.activo == true;
    }
    function canModerate() {
      return isAdmin() || isModerator();
    }
    function noDni(text) {
      return text is string
        && !text.matches('.*[0-9]{8}[A-HJ-NP-TV-Zа-я].*')
        && !text.matches('.*[XYZ][0-9]{7}[A-HJ-NP-TV-Z].*');
    }
    // ══ Usuarios ════════════════════════════════════════════════════
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      // Usuario NO puede modificar su propio campo `role` ni `csRoles` (este
      // último lo escribe sólo la Cloud Function `csRedeemInvite` con Admin SDK).
      allow update: if isOwner(uid)
        && !('role' in request.resource.data.diff(resource.data).affectedKeys())
        && !('csRoles' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if isAdmin();

      // Casos docentes: DNI/NIE bloqueado, iniciales <= 4.
      match /cases/{cid} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid)
          && request.resource.data.initials is string
          && request.resource.data.initials.size() <= 4
          && noDni(request.resource.data.get('notes', ''));
        allow update: if isOwner(uid)
          && noDni(request.resource.data.get('notes', ''));
        allow delete: if isOwner(uid) || isAdmin();
      }

      // AI requests: lectura dueño/admin; escritura solo server (Cloud Function).
      match /aiRequests/{rid} {
        allow read: if isOwner(uid) || isAdmin();
        allow create, update, delete: if false;
      }

      // Quotas: lectura propia; escritura solo server.
      match /quotas/{date} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }

      // Progress: dueño lee/escribe.
      match /progress/{pid} {
        allow read, write: if isOwner(uid);
      }
    }

    // ══ AI Cache ════════════════════════════════════════════════════
    match /aiCache/{hash} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    // ══ Rate limit IP (solo server) ═════════════════════════════════
    match /rate_limits_ip/{id} {
      allow read, write: if false;
    }
    match /rate_limits/{id} {
      allow read, write: if false;
    }
    // Rate limit por usuario para embedQuery (RAG). Solo escribe la
    // Cloud Function via Admin SDK; ningún cliente accede directamente.
    match /rate_limits_embed/{uid} {
      allow read, write: if false;
    }

    // ══ Informes IA — cada usuario CRUD de los suyos ═══════════════
    // El admin puede LEER (no escribir) para conteos/auditoría en el panel.
    match /informes_ia/{docId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow update: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // ══ Per-user docs donde el docId == uid ════════════════════════
    // Admin tiene LEctura para auditoría/conteos del panel; escritura sigue
    // siendo exclusiva del dueño (privacidad por defecto).
    match /mis_plantillas/{docId} {
      allow read: if signedIn() && (docId == request.auth.uid || isAdmin());
      allow write: if signedIn() && docId == request.auth.uid;
    }
    match /mis_notebooks/{docId} {
      allow read: if signedIn() && (docId == request.auth.uid || isAdmin());
      allow write: if signedIn() && docId == request.auth.uid;
    }
    match /megacuaderno_backups/{docId} {
      allow read: if signedIn() && (docId == request.auth.uid || isAdmin());
      allow write: if signedIn() && docId == request.auth.uid;
    }
    // Boletín diario agregado por el cron `megaCuadernoDailyDigest`.
    // Lectura abierta a profesionales autenticados (lo muestra Hub Pro).
    match /megacuaderno_digests/{day} {
      allow read: if signedIn();
      allow create, update, delete: if false; // solo cron (Admin SDK)
    }
    match /plantillas_backup/{docId} {
      allow read, write: if signedIn() && docId == request.auth.uid;
    }

    // ══ Scan uploads ═══════════════════════════════════════════════
    // Admin tiene LECTURA para conteos/auditoría panel; escritura/borrado
    // siguen siendo exclusivas del dueño.
    match /scan_uploads/{docId} {
      allow create: if signedIn();
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // ══ Guardia pacientes (CRUD propio) ════════════════════════════
    // Admin tiene LECTURA para conteos/auditoría panel.
    match /guardia_pacientes/{docId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // ══ Triajes (QR) ═══════════════════════════════════════════════
    match /triajes/{docId} {
      allow create: if signedIn();
      // Read público (para que el paciente escanee QR sin login).
      allow read: if true;
      allow delete: if signedIn();
      allow update: if isAdmin();
    }

    // ══ Sugerencias: crear cualquier auth, leer moderador+ ═════════
    match /sugerencias/{docId} {
      allow create: if signedIn();
      allow read: if canModerate();
      allow update, delete: if canModerate();
    }
    match /propuestas_contenido/{docId} {
      allow create: if signedIn();
      allow read: if signedIn();
      // Moderador/admin pueden cambiar estado y borrar propuestas.
      allow update: if canModerate();
      allow delete: if canModerate();
    }

    // ══ Documentos aprobados — todos leen, moderador+ escribe ═════
    match /documentos_aprobados/{docId} {
      allow read: if signedIn();
      allow write: if canModerate();
    }

    // ══ Moderadores/accesos ════════════════════════════════════════
    // Lectura abierta a profesionales autenticados (el frontend lo
    // necesita para construir moderadoresCache y enseñar el badge en
    // el header). Escritura sólo superadmin (isAdmin con custom claim
    // o emails hardcoded — un moderador NO puede crearse otros pares).
    match /moderadores/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /accesos_profesionales/{docId} {
      allow read, write: if isAdmin();
    }

    // ══ Platform config / ai_audit_log (legacy) ═══════════════════
    match /platform_config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /ai_audit_log/{docId} {
      allow create: if signedIn();
      allow read: if isAdmin();
      allow update, delete: if false;
    }
    match /config/{docId} {
      // ops_status es público (lo lee /status.html sin auth).
      allow read: if docId == 'ops_status' || signedIn();
      allow write: if isAdmin();
    }

    // ══ Healthchecks IA (escribe cron, lee público via /status.html) ══
    match /healthchecks/{day} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // ══ Gold-standard: admin CRUD, cron escribe resultados ═══════════
    match /eval_goldstandard/{caseId} {
      allow read, write: if isAdmin();
    }
    match /eval_results/{monthId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ══ Métricas (solo server escribe, admin lee) ══════════════════
    match /metrics_snapshots/{id} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ══ Audit log inmutable ════════════════════════════════════════
    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if false; // solo server (trigger Cloud Function)
      allow update, delete: if false;
    }

    // ══ Contadores de visitas públicas ═════════════════════════════
    // Permite increment +1 anónimo (uso: landing pacientes sin login).
    // Rule valida que count no decrezca y solo cambien campos permitidos.
    match /stats/{statDoc} {
      allow read: if isAdmin();
      allow create: if request.resource.data.keys().hasOnly(['count','updatedAt','lastVisit'])
                 && request.resource.data.count is int
                 && request.resource.data.count >= 0
                 && request.resource.data.count <= 1;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count','updatedAt','lastVisit'])
                 && request.resource.data.count is int
                 && request.resource.data.count >= resource.data.count;
      allow delete: if isAdmin();
    }

    // ══ Centros de Salud (Área II) ═════════════════════════════════
    // Directorio editable por equipos locales. Cada profesional autenticado
    // lee TODOS los centros (interconexión); sólo el redactor/coordinador del
    // centro (rol en /users/{uid}.csRoles[centroId]) — o un admin global —
    // puede escribir. Los códigos de invitación viven en /cs_invites y se
    // canjean vía Cloud Function `csRedeemInvite` (no escritura directa).
    function csRol(cid) {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid))
            .data.get('csRoles', {}).get(cid, '')
        : '';
    }
    // Cualquier rol no vacío = miembro del centro (residente, adjunto,
    // redactor o coordinador). Suficiente para LEER el foro privado.
    function csEsMiembro(cid) {
      return isAdmin() || csRol(cid) != '';
    }
    // Sólo redactor/coordinador editan la ficha del centro y subcolecciones
    // públicas (recursos, calendario, etc.).
    function csCanWrite(cid) {
      return isAdmin() || csRol(cid) == 'redactor' || csRol(cid) == 'coordinador';
    }
    match /centros_salud/{cid} {
      allow read: if signedIn();
      allow create, update: if csCanWrite(cid);
      allow delete: if isAdmin();

      // Foro privado del centro — acceso restringido a miembros (cualquiera
      // con rol no-vacío en csRoles[cid]). Residentes pueden preguntar y
      // adjuntos/coordinadores responder. Los autores editan/borran su
      // propio contenido; admin todo.
      match /foro/{qid} {
        allow read: if csEsMiembro(cid);
        allow create: if csEsMiembro(cid)
          && request.resource.data.autorUid == request.auth.uid;
        // Update libre para el autor; los miembros pueden cambiar sólo
        // los campos de votos/respuestaAceptadaId (resolver) si lo permite
        // el coordinador. Para simplicidad v1: autor o coordinador/admin.
        allow update: if isAdmin()
          || (csEsMiembro(cid) && resource.data.autorUid == request.auth.uid)
          || csCanWrite(cid);
        allow delete: if isAdmin()
          || (csEsMiembro(cid) && resource.data.autorUid == request.auth.uid)
          || csCanWrite(cid);

        match /respuestas/{rid} {
          allow read: if csEsMiembro(cid);
          allow create: if csEsMiembro(cid)
            && request.resource.data.autorUid == request.auth.uid;
          allow update: if isAdmin()
            || (csEsMiembro(cid) && resource.data.autorUid == request.auth.uid)
            || csCanWrite(cid);
          allow delete: if isAdmin()
            || (csEsMiembro(cid) && resource.data.autorUid == request.auth.uid)
            || csCanWrite(cid);
        }
      }

      // Subcolecciones públicas (lectura libre autenticada, escritura
      // sólo redactor/coordinador). Listadas explícitamente para que el
      // foro privado NO herede el read:signedIn() de un wildcard.
      match /actividades/{docId} {
        allow read: if signedIn();
        allow create, update, delete: if csCanWrite(cid);
      }
      match /calendario/{docId} {
        allow read: if signedIn();
        allow create, update, delete: if csCanWrite(cid);
      }
      match /avisos/{docId} {
        allow read: if signedIn();
        allow create, update, delete: if csCanWrite(cid);
      }
      match /documentos/{docId} {
        allow read: if signedIn();
        allow create, update, delete: if csCanWrite(cid);
      }
    }

    // Códigos de invitación: se crean y se canjean SOLO desde Cloud Function
    // (Admin SDK). El cliente no puede leerlos ni escribirlos directamente.
    match /cs_invites/{codigo} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // Tablón global del Área II (sólo admin publica; todos leen).
    match /area2_global/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
      match /{sub}/{subId} {
        allow read: if signedIn();
        allow write: if isAdmin();
      }
    }

    // ══ EvidenciaIA · búsquedas bibliográficas con síntesis ═══════
    // Cada consulta del usuario queda registrada con metadata mínima
    // (sin texto sintetizado completo — eso lo guarda solo si la
    // Cloud Function lo añade). El admin lee todas para auditoría
    // EU AI Act (art. 12, trazabilidad). El usuario solo lee las suyas.
    match /evidencia_consultas/{id} {
      // Cliente NO escribe directamente — todo pasa por Cloud Function
      // `evidenciaSearch` (Admin SDK). Garantiza que el flag de
      // disclaimer Art. 50 viaja siempre y que la pregunta queda
      // sanitizada antes de tocar Firestore.
      allow create, update, delete: if false;
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isAdmin());
    }
    match /evidencia_feedback/{id} {
      allow create, update, delete: if false; // solo Cloud Function
      allow read: if isAdmin();
    }
    match /evidenciaCache/{hash} {
      // Cualquier autenticado lee (cache compartida acelera todas las
      // consultas). Solo servidor escribe.
      allow read: if signedIn();
      allow create, update, delete: if false;
    }
    // Favoritos por usuario: el propio dueño lee la lista. La escritura
    // siempre pasa por Cloud Function `evidenciaToggleFavorite` (Admin
    // SDK), que valida que el dueño sea quien marca y que la consulta
    // exista — desde cliente directo no se permite para evitar que un
    // usuario se favorite consultas inexistentes o de otros.
    match /users/{uid}/evidenciaFavoritos/{consultaId} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    // ══ Solicitudes RGPD (derechos arts. 15-22) ═════════════════════
    // Cualquier autenticado crea su propia solicitud (uid debe coincidir
    // con request.auth.uid para impedir suplantación). Solo admin lee y
    // actualiza estado. Retención 5 años para acreditación AEPD.
    match /derechos_rgpd/{id} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.estado == 'pendiente';
      allow read: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ══ Cola de correo (Firebase Trigger Email extension) ═══════════
    // El moderador encola un correo al aprobar una propuesta. La
    // extensión `firestore-send-email` lee este doc y lo despacha.
    // Si la extensión NO está instalada, el doc queda inerte (no rompe).
    // Reglas: moderador o admin crea; nadie lee/edita después (la
    // extensión opera con permisos de servicio).
    match /mail/{id} {
      // Moderador/admin: cualquier mail.
      // Cualquier signedIn: SOLO mail kind='rgpd_solicitud' con destinos
      // restringidos (su email + admin), para no convertir /mail en spam relay.
      allow create: if canModerate()
        || (signedIn()
            && request.resource.data.kind == 'rgpd_solicitud'
            && request.resource.data.to is list
            && request.resource.data.to.size() <= 2);
      allow read, update, delete: if isAdmin();
    }

    // ══ Centros (multi-tenancy, Fase 1) ════════════════════════════
    // Catálogo de centros/tenants. Lectura abierta para profesionales
    // autenticados (el cliente necesita el nombre, logo y color del
    // centro activo). Escritura sólo por superadmins.
    match /centros/{centroId} {
      allow read: if signedIn();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ══ Collection groups ═════════════════════════════════════════
    // Admin dashboard: lectura cross-user de aiRequests/quotas solo para admins.
    // Los usuarios siguen accediendo a su subcolección propia vía las reglas de
    // /users/{uid}/aiRequests por owner. Aquí habilitamos el collectionGroup.
    match /{path=**}/aiRequests/{rid} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
    match /{path=**}/quotas/{date} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ══ DENY BY DEFAULT ════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
